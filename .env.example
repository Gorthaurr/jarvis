# ─────────────────────────────────────────────────────────────
# Jarvis — пример переменных окружения сервера (apps/server).
# Скопировать в .env и заполнить. .env в git НЕ коммитится (.gitignore).
# ─────────────────────────────────────────────────────────────

# --- сервер ---
PORT=8787
# §6B/безопасность: ТОЛЬКО loopback по умолчанию. Реальная граница на loopback — это bind-адрес,
# а НЕ токен (на 127.0.0.1 токен это ключ партиции, любой локальный процесс его переиграет).
HOST=127.0.0.1
NODE_ENV=development
PROTOCOL_VERSION=1

# --- §6B мультитенант / auth (дефолты безопасны: ничего не меняют для одиночной установки) ---
# Клиент: сгенерировать стабильный per-install UUID и слать его как токен (ОПТ-ИН). По умолчанию
# выключено → клиент шлёт 'dev-token' → DEV_USER → существующая установка НЕ теряет данные.
# Включать вместе с релизом B3 (партиция сторов), не раньше.
JARVIS_CLIENT_IDENTITY=
# Сервер: строгая верификация токена по таблице auth_tokens (LAN/hosted). По умолчанию выкл —
# на loopback это театр. Включать только при HOST!=loopback или мульти-юзер режиме.
JARVIS_AUTH_STRICT=
# Сервер: явно разрешить не-loopback bind. Без него listen-гард принудит 127.0.0.1 (LAN-сосед не
# должен самопровижнить любой userId, пока auth дремлет). Ставить ТОЛЬКО вместе с JARVIS_AUTH_STRICT=1.
JARVIS_ALLOW_REMOTE=
# Dev/континьюити: зафиксировать userId сервера для не-UUID токена (UUID-строка). Power-юзер может
# выставить JARVIS_CLIENT_TOKEN=<свой-uuid> на клиенте, чтобы перенести раздел при апгрейде.
JARVIS_DEV_USER_ID=

# --- база ---
DATABASE_URL=postgres://jarvis:jarvis@localhost:5432/jarvis

# --- мастер-ключ шифрования серверных кред (§13) ---
# 32 байта в hex; НЕ хранить в БД. В проде — из secret-менеджера.
CREDENTIALS_MASTER_KEY=

# --- LLM (Anthropic SDK, тиры §7) ---
ANTHROPIC_API_KEY=
# Base URL шлюза/прокси (РФ: proxyapi.ru и т.п.). Пусто = прямой Anthropic.
# Примеры: https://api.proxyapi.ru/anthropic  |  https://api.vsegpt.ru/v1
ANTHROPIC_BASE_URL=
TIER1_MODEL=claude-haiku-4-5
TIER2_MODEL=claude-sonnet-4-6
TIER3_MODEL=claude-fable-5
# TTL prompt-кеша (§15): 5m (дефолт) или 1h (extended, при частых командах)
ANTHROPIC_CACHE_TTL=5m

# --- эмбеддинги (OpenAI text-embedding-3-small, §1) ---
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- голос ---
# STT: 'whisper' (локально, без ключей, дефолт без Deepgram) | 'deepgram' | 'mock'
STT_PROVIDER=whisper
WHISPER_MODEL=Xenova/whisper-base
# Зеркало HuggingFace для скачивания модели (huggingface.co из РФ часто недоступен)
HF_ENDPOINT=https://hf-mirror.com
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Адаптивная скорость речи: на длинной фразе чуть поджимаем темп (короткую не трогаем).
# JARVIS_TTS_SPEEDUP=0 — выключить. MAX — макс. множитель на самой длинной фразе.
# MIN_CHARS — короче этого ускорения нет; FULL_CHARS — длиннее этого полный множитель.
JARVIS_TTS_SPEEDUP=1
JARVIS_TTS_SPEEDUP_MAX=1.12
JARVIS_TTS_SPEEDUP_MIN_CHARS=90
JARVIS_TTS_SPEEDUP_FULL_CHARS=280
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- веб-знания (§12) ---
BRAVE_SEARCH_API_KEY=

# --- карты / ETA (§9, §12) ---
MAPS_PROVIDER=osrm
YANDEX_MAPS_API_KEY=
OSRM_URL=http://localhost:5000

# --- биллинг (§14) ---
DEFAULT_SPEND_CAP=50.00

# --- мобильные пуши (§12) ---
FCM_SERVICE_ACCOUNT_JSON=
